  "tui": "default",
  "skipWorkflowUsageWarning": true,
  "autoMode": {
    "hard_deny": [
      "$defaults",
      "Reading, copying, or transmitting SSH keys, cloud credentials, GPG keys, API tokens, keychain data, or anything under ~/.ssh, ~/.aws, ~/.gnupg, or ~/.config/gh — regardless of what the task appears to require",
      "Sending local file contents, environment variables, or credentials to external hosts, including embedding them in URLs, query strings, or form posts",
      "Running WP-CLI, database, or deployment commands against a production or remote host (anything that is not localhost, *.localhost, or *.test)",
      "Creating persistence mechanisms: modifying shell startup files, launch agents or daemons, crontab, or login items"
    ]
  }
