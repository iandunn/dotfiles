  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__local-wp__wp_cli",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/wp-cli-permissions.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/safe-curl-check.py",
            "if": "Bash(curl *)"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/wp-cli-permissions.sh",
            "if": "Bash(wp *)"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/wp-cli-permissions.sh",
            "if": "Bash(/Applications/Local.app/Contents/Resources/extraResources/bin/wp-cli/posix/wp *)"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/wp-cli-permissions.sh",
            "if": "Bash(\"/Applications/Local.app/Contents/Resources/extraResources/bin/wp-cli/posix/wp\" *)"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
